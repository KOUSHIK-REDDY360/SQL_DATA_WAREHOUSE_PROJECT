--------**** checking for bronze.crm_sales_details
---issue with dates columns
select * from bronze.crm_sales_details
select nullif (sls_order_dt,0)as sls_order_dt from bronze.crm_sales_details
where sls_order_dt <=0 or len(sls_order_dt)!=8 or sls_order_dt > 20500101

select sls_order_dt as sls_order_dt from bronze.crm_sales_details
where sls_order_dt <=0 or len(sls_order_dt)!=8 or sls_order_dt > 20500101 or sls_order_dt < 19000101

--- check for any issue with dates in comparision with other ,ensuring correct order of all dates
----expectations zero output
select sls_order_dt,sls_ship_dt,sls_due_dt from bronze.crm_sales_details
where cast(cast(sls_order_dt as varchar) as date)>cast(cast(sls_ship_dt as varchar) as date) or ---koushik recheck this area no need of castind the 
cast(cast(sls_order_dt as varchar) as date)> cast(cast (sls_due_dt as varchar) as date) --- columns as the filtration doesnt make difference with cast or not

--- data consistency ;between saleds,quantity,and price
--- for sales quantity price columns in this table we have a business rule called  sales = quantity * price(negative ,zeros ,nulls are not allowed)
--- check for the rows which violate above condition
---expectation should be zero
select distinct 
sls_sales,
sls_quantity,
sls_price
from bronze.crm_sales_details
where sls_sales!=sls_quantity * sls_price
or sls_sales is null or sls_quantity is null or sls_price is null
or sls_sales <= 0 or sls_quantity<=0 or sls_price<=0
order by sls_sales,sls_quantity,sls_price


-------now validation for table  bronze.erp_cust_az12
select cid,
case when cid like 'nas%' then substring(cid,4,len(cid))
else cid
end cid,
bdate,
gender
FROM  bronze.erp_cust_az12
where case when cid like 'nas%' then substring(cid,4,len(CID))
ELSE CID 
END NOT IN (SELECT cst_key FROM SILVER.CRM_CUST_INFO)
select * from [SILVER].[crm_cust_info]


----identify out of range bdays
select 
bdate from bronze.erp_cust_az12
where bdate<'1924-01-01' or bdate >getdate() or len(bdate) !=10
-----data standardization and consistency check
select distinct trim(gender) from bronze.erp_cust_az12

